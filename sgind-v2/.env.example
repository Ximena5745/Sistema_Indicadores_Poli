# ── General ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=sgind
POSTGRES_PASSWORD=sgind_dev_password
POSTGRES_DB=sgind
DATABASE_URL=postgresql+asyncpg://sgind:sgind_dev_password@localhost:5432/sgind

# ── Backend (FastAPI) ────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:3000

# ── Microsoft Entra ID (OIDC) ────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
ALLOWED_EMAILS=admin@poligran.edu.co

# ── Datos Excel (sistema legacy, solo lectura) ─────────────────────
# Ruta absoluta al directorio data/ del proyecto Streamlit
SGIND_DATA_PATH=../data

# ── Excel cache ──────────────────────────────────────────────────
EXCEL_CACHE_TTL_SECONDS=300

# ── Frontend (Next.js) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=SGIND
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# ── IA (opcional, Fase 8) ────────────────────────────────────────
ANTHROPIC_API_KEY=
