# ─── Entorno ─────────────────────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sgind:sgind_dev_password@localhost:5433/sgind

# ─── Seguridad JWT ────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Azure AD (Autenticación institucional) ───────────────────────────────────
# 1. Ir a portal.azure.com → Azure Active Directory → App registrations → New registration
# 2. Nombre: SGIND v2 (o similar)
# 3. Redirect URI: http://localhost:8000/api/v1/auth/callback (Web)
# 4. Copiar Application (client) ID → AZURE_CLIENT_ID
# 5. Copiar Directory (tenant) ID → AZURE_TENANT_ID
# 6. Certificates & secrets → New client secret → copiar valor → AZURE_CLIENT_SECRET
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# URL de callback del backend (debe coincidir con el redirect URI en Azure)
AZURE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Emails permitidos (vacío = cualquier email del tenant)
# Separados por coma: user1@poligran.edu.co,user2@poligran.edu.co
ALLOWED_EMAILS=

# ─── Datos Excel ─────────────────────────────────────────────────────────────
SGIND_DATA_PATH=../../data
EXCEL_CACHE_TTL_SECONDS=300
