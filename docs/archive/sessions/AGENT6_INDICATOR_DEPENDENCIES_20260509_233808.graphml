<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlformat/graphml">
  <graph edgedefault="directed">
    <node id="cumplimiento_academico" label="Cumplimiento Académico" size="40"/>
    <node id="cumplimiento_administrativo" label="Cumplimiento Administrativo" size="35"/>
    <node id="cumplimiento_bienestar" label="Cumplimiento Bienestar" size="35"/>
    <node id="cmi_estrategico" label="CMI Estratégico" size="35"/>
