    <node id="desempeño_general" label="Desempeño General" size="30"/>
    <node id="tendencia_academica" label="Tendencia Académica" size="30"/>
    <edge source="cumplimiento_academico" target="campo_total_cumplido" label="depende_de"/>
    <edge source="cumplimiento_administrativo" target="campo_total_cumplido" label="depende_de"/>
    <edge source="cumplimiento_bienestar" target="campo_total_cumplido" label="depende_de"/>
    <edge source="ejecucion_presupuestal" target="campo_gastos_reales" label="depende_de"/>
    <edge source="cmi_estrategico" target="cumplimiento_academico" label="compuesto_de"/>
