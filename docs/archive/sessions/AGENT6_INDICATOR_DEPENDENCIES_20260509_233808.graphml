    <edge source="cmi_estrategico" target="cumplimiento_bienestar" label="compuesto_de"/>
    <edge source="desempeño_general" target="cmi_estrategico" label="compuesto_de"/>
    <edge source="desempeño_general" target="ejecucion_presupuestal" label="compuesto_de"/>
    <edge source="tendencia_academica" target="cumplimiento_academico" label="transforma"/>
  </graph>
</graphml>