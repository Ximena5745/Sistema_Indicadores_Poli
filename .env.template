# CONFIGURACIÓN DE NOTIFICACIONES PRODUCCIÓN
## .env (NO commitear — archivo local)

# ───────────────────────────────────────────────────────────────
# EMAIL NOTIFICATIONS (SMTP)
# ───────────────────────────────────────────────────────────────

# Servidor SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Cuenta de envío (email institucional o servicio de alertas)
SENDER_EMAIL=sgind-alerts@politecnico.edu.co
SENDER_PASSWORD=tu_contraseña_aqui  # Usar variable de entorno en producción

# Destinatarios (separados por semicolon)
RECIPIENT_EMAILS=ops@politecnico.edu.co;dba@politecnico.edu.co;directivo@politecnico.edu.co

# ───────────────────────────────────────────────────────────────
# SLACK NOTIFICATIONS (Webhook)
# ───────────────────────────────────────────────────────────────

# Webhook de Slack (canal #sgind-alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ───────────────────────────────────────────────────────────────
# SISTEMA
# ───────────────────────────────────────────────────────────────

# Modo de ejecución
ENVIRONMENT=production

# Path de versionado/backup
VERSION_BACKUP_DIR=data/backups/

# ───────────────────────────────────────────────────────────────
# NOTAS
# ───────────────────────────────────────────────────────────────

# 1. SMTP Setup (Gmail):
#    - Habilitar "Acceso de apps menos seguros" O usar token de apps
#    - 2FA debe estar DESACTIVADO en la cuenta
#    - Alternativa: usar SendGrid/AWS SES (requiere setup adicional)

# 2. Slack Webhook:
#    - Crear webhook en: https://api.slack.com/apps/
#    - Asignar canal #sgind-alerts
#    - Revisar permisos: chat:write

# 3. Seguridad:
#    - NUNCA commitear .env a git
#    - En producción: usar AWS Secrets Manager, HashiCorp Vault, o env vars del servidor
#    - Para testing: usar .env.test con valores dummy

# 4. Testing Local:
#    - Crear .env.local con valores reales
#    - Ejecutar: python scripts/etl/notifications.py test
#    - Verificar que los emails/Slack se envíen correctamente
